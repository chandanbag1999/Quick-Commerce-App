{
  "name": "gobasket-backend",
  "version": "1.0.0",
  "description": "Quick commerce backend like Zepto — built with Fastify, TypeScript, PostgreSQL",
  "main": "dist/server.js",
  "type": "module",
  "scripts": {
    "dev": "cross-env PORT=3000 tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write src"
  },
  "keywords": [
    "fastify",
    "typescript",
    "postgresql",
    "quick-commerce"
  ],
  "author": "Lucifer Morningstar",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^25.9.3",
    "cross-env": "^10.1.0",
    "pino-pretty": "^13.1.3",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  },
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@fastify/helmet": "^13.0.2",
    "@fastify/rate-limit": "^11.0.0",
    "@fastify/swagger": "^9.7.0",
    "@fastify/swagger-ui": "^6.0.0",
    "dotenv": "^16.6.1",
    "fastify": "^5.8.5",
    "fastify-plugin": "^6.0.0",
    "zod": "^4.4.3"
  }
}